generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("STELLAR_PSQL_URI")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CommunityType {
  Music
  Applications
  EBooks
  ELearningVideos
  Audiobooks
  Comedy
  Comics
}

enum FileType {
  mp3
  flac
  wav
  ogg
  aac
  m4a
  m4b
  mp4
  mkv
  avi
  mov
  zip
  exe
  dmg
  apk
  pdf
  epub
  mobi
  cbz
  cbr
  jpg
  png
  gif
  txt
}

enum InviteStatus {
  pending
  accepted
  rejected
}

enum RegistrationStatus {
  open
  invite
  closed
}

enum ReleaseType {
  Music
  Applications
  EBooks
  ELearningVideos
  Audiobooks
  Comedy
  Comics
}

enum ReleaseCategory {
  Album
  Single
  EP
  Anthology
  Compilation
  DJMix
  Live
  Remix
  Bootleg
  Interview
  Mixtape
  Demo
  ConcertRecording
  Unknown
}

enum CommentPage {
  artist
  collages
  contributions
  requests
  communities
  release
}

enum SubscriptionPage {
  forums
  artist
  collages
  requests
  communities
  contributions
  release
}

enum NotificationType {
  forum_quote
  forum_sub
  request_filled
  collage_updated
  comment_sub
  artist_release
}

enum ThreadType {
  forum
  application
}

enum ApiUserState {
  inactive
  active
}

enum NoteVisibility {
  public
  staff
}

enum ForumRuleTarget {
  Forum
  Thread
  Topic
}

enum RequestStatus {
  open
  filled
  deleted
}

enum NotificationMethod {
  Disabled
  Popup
  Traditional
  Push
  Combined
}

enum EconomyTransactionReason {
  REQUEST_CREATE
  REQUEST_VOTE
  REQUEST_FILL
  REQUEST_UNFILL
  REQUEST_REFUND
  DOWNLOAD_DEBIT
  DOWNLOAD_CREDIT
  STAFF_REVERSAL
}

enum DownloadGrantStatus {
  COMPLETED
  REVERSED
}

enum RatioPolicyStatus {
  OK
  WATCH
  LEECH_DISABLED
}

enum LinkHealthStatus {
  UNKNOWN
  PASS
  WARN
  FAIL
}

enum RequestActionType {
  CREATE
  ADD_BOUNTY
  FILL
  UNFILL
  DELETE
  RESTORE
}

enum StaffInboxStatus {
  Unanswered
  Open
  Resolved
}

enum ReportStatus {
  Open
  Claimed
  Resolved
}

enum ReportTargetType {
  User
  Release
  Artist
  Contribution
  ForumTopic
  ForumPost
  Comment
  Collage
  Post
}

enum ReportResolutionAction {
  Dismissed
  ContentRemoved
  UserWarned
  UserDisabled
  MetadataFixed
  MarkedDuplicate
  Other
}

enum ReleaseReportCategory {
  Dupe
  Trump
  BadFileNamesTrump
  BadFolderNameTrump
  TagTrump
  VinylTrump
  AudienceRecording
  BadFileNames
  BadFolderNames
  BadTagNoTag
  BonusTracksOnly
  DisallowedFormat
  DiscsMissing
  Discography
  MqaBanned
  EditedLog
  InaccurateBitrate
  LogRescoreRequest
  LossyMasterApprovalRequest
  ContributionContestApprovalRequest
  LowBitrate
  MuttRip
  NoLineageInfo
  Other
  RadioTvFmWebRip
  SkipsEncodeErrors
  SpecificallyBanned
  TracksMissing
  Transcode
  UnsplitAlbumRip
  Urgent
  UserCompilation
  WrongSpecifiedFormat
  WrongSpecifiedMedia
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model UserRank {
  id                   Int    @id @default(autoincrement())
  level                Int
  name                 String
  permissions          Json
  color                String @default("")
  badge                String @default("")
  uploadRequired       Int    @default(0)
  personalCollageLimit Int    @default(0)
  users                User[]

  @@map("user_ranks")
}

model UserSettings {
  id                   Int                @id @default(autoincrement())
  siteAppearance       String             @default("cayer_make")
  externalStylesheet   String?
  styledTooltips       Boolean            @default(true)
  paranoia             Int                @default(0)
  notificationMethod   NotificationMethod @default(Popup)
  showEmail            Boolean            @default(false)
  showLastSeen         Boolean            @default(false)
  showContributedStats Boolean            @default(true)
  showConsumedStats    Boolean            @default(true)
  showRatioStats       Boolean            @default(true)
  user                 User?

  @@map("user_settings")
}

model User {
  id                 Int          @id @default(autoincrement())
  username           String       @unique
  email              String       @unique
  password           String
  avatar             String?
  userRankId         Int
  userRank           UserRank     @relation(fields: [userRankId], references: [id])
  userSettingsId     Int          @unique
  userSettings       UserSettings @relation(fields: [userSettingsId], references: [id])
  profileId          Int          @unique
  profile            Profile      @relation(fields: [profileId], references: [id])
  inviteCount        Int          @default(0)
  contributed        BigInt       @default(0)
  consumed           BigInt       @default(0)
  totalEarned        BigInt       @default(0)
  ratio              Float        @default(1)
  ratioWatchDownload Int?
  lastLogin          DateTime?
  dateRegistered     DateTime     @default(now())
  disabled           Boolean      @default(false)
  isArtist           Boolean      @default(false)
  isDonor            Boolean      @default(false)
  canDownload        Boolean      @default(true)
  adminComment       String?
  banDate            DateTime?
  banReason          String?
  warned             DateTime?
  warnedTimes        Int          @default(0)
  lastIp             String?
  communityPass      String       @default("")
  disablePm          Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  invitesSent           Invite[]
  inviteTree            InviteTree[]
  friends               Friend[]              @relation("UserFriends")
  friendOf              Friend[]              @relation("FriendOf")
  communityStaff        Community[]           @relation("CommunityStaff")
  consumer              Consumer?
  contributor           Contributor?
  contributions         Contribution[]
  forumTopics           ForumTopic[]
  forumPosts            ForumPost[]
  forumTopicNotes       ForumTopicNote[]
  artistHistories       ArtistHistory[]       @relation("HistoryEditedBy")
  collages              Collage[]             @relation("CollageCreator")
  collageEntries        CollageEntry[]        @relation("CollageEntryAdder")
  collageSubscriptions  CollageSubscription[] @relation("CollageSubscriber")
  bookmarkArtists       BookmarkArtist[]
  bookmarkCollages      BookmarkCollage[]
  bookmarkReleases      BookmarkRelease[]
  bookmarkCommunities   BookmarkCommunity[]
  bookmarkRequests      BookmarkRequest[]
  subscriptions         Subscription[]
  commentSubscriptions  CommentSubscription[]
  artistSubscriptions   ArtistSubscription[]
  notifications         Notification[]        @relation("NotificationUser")
  actedNotifications    Notification[]        @relation("NotificationActor")
  blogs                 Blog[]
  posts                 Post[]
  apiApplications       ApiApplication[]
  apiUsers              ApiUser[]
  donorReward           DonorReward?
  donorForumUsername    DonorForumUsername?
  donations             Donation[]
  notes                 Note[]
  applicants            Applicant[]
  comments              Comment[]             @relation("CommentAuthor")
  editedComments        Comment[]             @relation("CommentEditor")
  postComments          PostComment[]
  forumPostEdits        ForumPostEdit[]
  auditLogs             AuditLog[]
  requests                  Request[]             @relation("RequestAuthor")
  filledRequests            Request[]             @relation("RequestFiller")
  requestBounties           RequestBounty[]
  economyTransactions       EconomyTransaction[]
  economyActed              EconomyTransaction[]  @relation("EconomyActor")
  requestActions            RequestAction[]       @relation("RequestActionActor")
  requestFills              RequestFill[]         @relation("RequestFillFiller")
  downloadGrantsAsConsumer  DownloadAccessGrant[] @relation("DownloadConsumer")
  downloadGrantsAsContrib   DownloadAccessGrant[] @relation("DownloadContributor")
  downloadGrantsReversed    DownloadAccessGrant[] @relation("DownloadGrantReversedBy")
  ratioPolicyState          RatioPolicyState?
  contributionReports       ContributionReport[]
  pmParticipations          PrivateConversationParticipant[] @relation("PmParticipant")
  pmMessagesSent            PrivateMessage[]                 @relation("PmSender")
  staffInboxConversations   StaffInboxConversation[]         @relation("StaffInboxOwner")
  staffInboxAssigned        StaffInboxConversation[]         @relation("StaffInboxAssignee")
  staffInboxResolved        StaffInboxConversation[]         @relation("StaffInboxResolver")
  staffInboxMessages        StaffInboxMessage[]              @relation("StaffInboxMsgSender")
  reportsFiled              Report[]                         @relation("ReportFiler")
  reportsClaimed            Report[]                         @relation("ReportClaimer")
  reportsResolved           Report[]                         @relation("ReportResolver")
  reportNotes               ReportNote[]                     @relation("ReportNoteAuthor")
  sessions                  UserSession[]
  accountRecoveries         AccountRecovery[]
  emailHistories            UserEmailHistory[]
  warnings                  UserWarning[]                    @relation("UserWarnings")
  warningsIssued            UserWarning[]                    @relation("UserWarnedBy")
  moderationNotes           UserModerationNote[]             @relation("UserModerationNotes")
  moderationNotesAuthored   UserModerationNote[]             @relation("ModerationNoteAuthor")
  pmDrafts                  PmDraft[]
  massMessagesSent          MassMessage[]                    @relation("MassMessageSender")
  siteHistoryEntries        SiteHistory[]
  requestVotes              RequestVote[]
  releaseVotes              ReleaseVote[]
  releaseTagVotes           ReleaseTagVote[]
  releaseTagsAdded          ReleaseTag[]   @relation("ReleaseTagAdder")
  releaseHistoriesAuthored  ReleaseHistory[] @relation("ReleaseHistoryActor")
  donorRank                 UserDonorRank?
  wikiPagesAuthored         WikiPage[]     @relation("WikiPageAuthor")
  wikiRevisionsAuthored     WikiRevision[] @relation("WikiRevisionAuthor")
  wikiAliasesCreated        WikiAlias[]    @relation("WikiAliasCreator")

  @@index([userRankId])
  @@map("users")
}

model Invite {
  id        Int          @id @default(autoincrement())
  inviterId Int
  inviter   User         @relation(fields: [inviterId], references: [id])
  inviteKey String       @unique
  email     String       @unique
  expires   DateTime
  reason    String       @default("")
  status    InviteStatus @default(pending)

  @@index([status])
  @@map("invites")
}

model InviteTree {
  id           Int  @id @default(autoincrement())
  userId       Int
  user         User @relation(fields: [userId], references: [id])
  inviterId    Int
  treePosition Int  @default(1)
  treeId       Int  @default(1)
  treeLevel    Int  @default(0)

  @@map("invite_trees")
}

model Friend {
  id       Int    @id @default(autoincrement())
  userId   Int
  user     User   @relation("UserFriends", fields: [userId], references: [id])
  friendId Int
  friend   User   @relation("FriendOf", fields: [friendId], references: [id])
  comment  String @default("")

  @@unique([userId, friendId])
  @@map("friends")
}

// ─── Profile ──────────────────────────────────────────────────────────────────

model Profile {
  id                  Int     @id @default(autoincrement())
  avatar              String?
  avatarMouseoverText String?
  profileTitle        String?
  profileInfo         String? @db.Text
  user                User?

  @@map("profiles")
}

model Stylesheet {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  cssUrl    String
  createdAt DateTime @default(now())

  @@map("stylesheets")
}

// ─── Forum ────────────────────────────────────────────────────────────────────

model ForumCategory {
  id     Int     @id @default(autoincrement())
  name   String
  sort   Int
  forums Forum[]

  @@map("forum_categories")
}

model Forum {
  id              Int                 @id @default(autoincrement())
  forumCategoryId Int
  forumCategory   ForumCategory       @relation(fields: [forumCategoryId], references: [id])
  sort            Int
  name            String
  description     String              @default("")
  minClassRead    Int                 @default(0)
  minClassWrite   Int                 @default(0)
  minClassCreate  Int                 @default(0)
  numTopics       Int                 @default(0)
  numPosts        Int                 @default(0)
  autoLock        Boolean             @default(true)
  autoLockWeeks   Int                 @default(4)
  isTrash         Boolean             @default(false)
  lastTopicId     Int?
  lastTopic       ForumTopic?         @relation("ForumLastTopic", fields: [lastTopicId], references: [id], onDelete: SetNull)
  topics          ForumTopic[]        @relation("ForumTopics")
  specificRules   ForumSpecificRule[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("forums")
}

model ForumTopic {
  id            Int                  @id @default(autoincrement())
  forumId       Int
  forum         Forum                @relation("ForumTopics", fields: [forumId], references: [id], onDelete: Restrict)
  threadId      Int?
  thread        Thread?              @relation(fields: [threadId], references: [id])
  title         String
  authorId      Int
  author        User                 @relation(fields: [authorId], references: [id])
  isLocked      Boolean              @default(false)
  isSticky      Boolean              @default(false)
  ranking       Int                  @default(0)
  numPosts      Int                  @default(0)
  lastPostId    Int?
  lastPost      ForumPost?           @relation("TopicLastPost", fields: [lastPostId], references: [id], onDelete: SetNull)
  posts         ForumPost[]          @relation("TopicPosts")
  lastForumOf   Forum[]              @relation("ForumLastTopic")
  notes         ForumTopicNote[]
  poll          ForumPoll?
  lastRead      ForumLastReadTopic[]
  concert       Concert?
  specificRules ForumSpecificRule[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?

  @@index([forumId])
  @@index([authorId])
  @@map("forum_topics")
}

model ForumPost {
  id           Int                  @id @default(autoincrement())
  forumTopicId Int
  forumTopic   ForumTopic           @relation("TopicPosts", fields: [forumTopicId], references: [id], onDelete: Cascade)
  authorId     Int
  author       User                 @relation(fields: [authorId], references: [id])
  body         String               @db.Text
  edits        ForumPostEdit[]
  lastPostOf   ForumTopic[]         @relation("TopicLastPost")
  lastReadOf   ForumLastReadTopic[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  deletedAt    DateTime?

  @@index([forumTopicId])
  @@index([authorId])
  @@map("forum_posts")
}

model ForumPostEdit {
  id           Int       @id @default(autoincrement())
  forumPostId  Int
  forumPost    ForumPost @relation(fields: [forumPostId], references: [id], onDelete: Cascade)
  editorId     Int
  editor       User      @relation(fields: [editorId], references: [id])
  previousBody String    @db.Text
  editedAt     DateTime  @default(now())

  @@index([forumPostId])
  @@map("forum_post_edits")
}

model ForumPoll {
  id           Int             @id @default(autoincrement())
  forumTopicId Int             @unique
  forumTopic   ForumTopic      @relation(fields: [forumTopicId], references: [id], onDelete: Cascade)
  question     String
  answers      String          @db.Text
  featured     DateTime?
  closed       Boolean         @default(false)
  votes        ForumPollVote[]

  @@map("forum_polls")
}

model ForumPollVote {
  id          Int       @id @default(autoincrement())
  forumPollId Int
  forumPoll   ForumPoll @relation(fields: [forumPollId], references: [id], onDelete: Cascade)
  userId      Int
  vote        Int

  @@unique([forumPollId, userId])
  @@map("forum_poll_votes")
}

model ForumLastReadTopic {
  id           Int        @id @default(autoincrement())
  userId       Int
  forumTopicId Int
  forumTopic   ForumTopic @relation(fields: [forumTopicId], references: [id], onDelete: Cascade)
  forumPostId  Int
  forumPost    ForumPost  @relation(fields: [forumPostId], references: [id], onDelete: Cascade)

  @@unique([userId, forumTopicId])
  @@map("forum_last_read_topics")
}

model ForumTopicNote {
  id           Int        @id @default(autoincrement())
  forumTopicId Int
  forumTopic   ForumTopic @relation(fields: [forumTopicId], references: [id], onDelete: Cascade)
  authorId     Int
  author       User       @relation(fields: [authorId], references: [id])
  body         String     @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("forum_topic_notes")
}

model ForumSpecificRule {
  id           Int             @id @default(autoincrement())
  targetType   ForumRuleTarget
  forumId      Int?
  forum        Forum?          @relation(fields: [forumId], references: [id], onDelete: SetNull)
  threadId     Int?
  thread       Thread?         @relation(fields: [threadId], references: [id])
  forumTopicId Int?
  forumTopic   ForumTopic?     @relation(fields: [forumTopicId], references: [id], onDelete: SetNull)

  @@map("forum_specific_rules")
}

model Thread {
  id            Int                 @id @default(autoincrement())
  type          ThreadType
  createdAt     DateTime            @default(now())
  forumTopics   ForumTopic[]
  applicants    Applicant[]
  notes         Note[]
  specificRules ForumSpecificRule[]

  @@map("threads")
}

// ─── Artist ───────────────────────────────────────────────────────────────────

model Artist {
  id             Int              @id @default(autoincrement())
  name           String
  vanityHouse    Boolean          @default(false)
  histories      ArtistHistory[]
  aliases        ArtistAlias[]    @relation("ArtistAliases")
  redirects      ArtistAlias[]    @relation("ArtistRedirects")
  tags           ArtistTag[]
  concerts       Concert[]
  similarTo      SimilarArtist[]  @relation("ArtistSimilar")
  similarFrom    SimilarArtist[]  @relation("SimilarArtistRef")
  releases       Release[]
  collaborations Contribution[]   @relation("ContributionCollaborators")
  bookmarks      BookmarkArtist[]
  comments       Comment[]
  RequestArtist  RequestArtist[]
  subscriptions  ArtistSubscription[]

  @@map("artists")
}

model ArtistHistory {
  id          Int      @id @default(autoincrement())
  artistId    Int
  artist      Artist   @relation(fields: [artistId], references: [id])
  data        Json
  editedBy    Int
  editedUser  User     @relation("HistoryEditedBy", fields: [editedBy], references: [id])
  editedAt    DateTime @default(now())
  description String?

  @@map("artist_histories")
}

model ArtistAlias {
  id         Int    @id @default(autoincrement())
  artistId   Int
  artist     Artist @relation("ArtistAliases", fields: [artistId], references: [id])
  redirectId Int
  redirect   Artist @relation("ArtistRedirects", fields: [redirectId], references: [id])
  userId     Int?

  @@map("artist_aliases")
}

model ArtistTag {
  id            Int    @id @default(autoincrement())
  artistId      Int
  artist        Artist @relation(fields: [artistId], references: [id])
  tagId         Int
  tag           Tag    @relation(fields: [tagId], references: [id])
  positiveVotes Int    @default(1)
  negativeVotes Int    @default(1)
  userId        Int?

  @@unique([artistId, tagId])
  @@index([artistId])
  @@map("artist_tags")
}

model ReleaseTag {
  id            Int              @id @default(autoincrement())
  releaseId     Int
  release       Release          @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  tagId         Int
  tag           Tag              @relation(fields: [tagId], references: [id], onDelete: Cascade)
  positiveVotes Int              @default(1)
  negativeVotes Int              @default(1)
  userId        Int?
  user          User?            @relation("ReleaseTagAdder", fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  votes         ReleaseTagVote[]

  @@unique([releaseId, tagId])
  @@index([releaseId])
  @@index([tagId])
  @@map("release_tags")
}

enum ReleaseTagVoteDirection {
  up
  down
}

model ReleaseTagVote {
  id           Int                     @id @default(autoincrement())
  releaseTagId Int
  releaseTag   ReleaseTag              @relation(fields: [releaseTagId], references: [id], onDelete: Cascade)
  userId       Int
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  direction    ReleaseTagVoteDirection
  createdAt    DateTime                @default(now())

  @@unique([releaseTagId, userId, direction])
  @@index([releaseTagId])
  @@index([userId])
  @@map("release_tag_votes")
}

model ArtistSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  artistId  Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, artistId])
  @@index([artistId])
  @@map("artist_subscriptions")
}

model Concert {
  id           Int        @id @default(autoincrement())
  artistId     Int
  artist       Artist     @relation(fields: [artistId], references: [id])
  forumTopicId Int        @unique
  forumTopic   ForumTopic @relation(fields: [forumTopicId], references: [id], onDelete: Cascade)

  @@map("concerts")
}

model SimilarArtist {
  id              Int    @id @default(autoincrement())
  artistId        Int
  artist          Artist @relation("ArtistSimilar", fields: [artistId], references: [id])
  similarArtistId Int
  similarArtist   Artist @relation("SimilarArtistRef", fields: [similarArtistId], references: [id])
  score           Int    @default(0)
  votes           Json   @default("[]")

  @@unique([artistId, similarArtistId])
  @@map("similar_artists")
}

// ─── Community ────────────────────────────────────────────────────────────────

model Community {
  id                     Int                 @id @default(autoincrement())
  name                   String              @unique
  description            String?             @db.Text
  image                  String
  registrationStatus     RegistrationStatus
  type                   CommunityType
  allowDuplicateFormats  Boolean             @default(true)
  consumers          Consumer[]          @relation("CommunityConsumers")
  contributors       Contributor[]
  releases           Release[]
  comments           Comment[]
  staff              User[]              @relation("CommunityStaff")
  doNotUpload        DoNotUpload[]
  bookmarks          BookmarkCommunity[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  Request            Request[]

  @@map("communities")
}

model Consumer {
  id            Int            @id @default(autoincrement())
  userId        Int            @unique
  user          User           @relation(fields: [userId], references: [id])
  releases      Release[]      @relation("ReleaseConsumers")
  communities   Community[]    @relation("CommunityConsumers")
  contributions Contribution[] @relation("ContributionConsumers")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("consumers")
}

model Contributor {
  id            Int            @id @default(autoincrement())
  userId        Int            @unique
  user          User           @relation(fields: [userId], references: [id])
  communityId   Int
  community     Community      @relation(fields: [communityId], references: [id])
  contributions Contribution[]
  releases      Release[]      @relation("ReleaseContributors")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("contributors")
}

model Release {
  id            Int               @id @default(autoincrement())
  artistId      Int
  artist        Artist            @relation(fields: [artistId], references: [id])
  title         String            @db.VarChar(100)
  image         String?
  description   String            @db.VarChar(1000)
  communityId   Int?
  community     Community?        @relation(fields: [communityId], references: [id])
  consumers     Consumer[]        @relation("ReleaseConsumers")
  contributors  Contributor[]     @relation("ReleaseContributors")
  contributions Contribution[]
  type          ReleaseType
  releaseType   ReleaseCategory
  year          Int
  isEdition        Boolean           @default(false)
  edition          Json?
  catalogueNumber  String?
  recordLabel      String?
  bookmarks        BookmarkRelease[]
  comments         Comment[]
  collageEntries   CollageEntry[]
  votes            ReleaseVote[]
  releaseTags      ReleaseTag[]
  historyEntries   ReleaseHistory[]
  voteAggregate    ReleaseVoteAggregate?
  snapshotEntries  Top10SnapshotEntry[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([artistId])
  @@index([communityId])
  @@index([year])
  @@index([createdAt])
  @@map("releases")
}

model Contribution {
  id                 Int           @id @default(autoincrement())
  userId             Int
  user               User          @relation(fields: [userId], references: [id])
  releaseId          Int
  release            Release       @relation(fields: [releaseId], references: [id])
  contributorId      Int
  contributor        Contributor   @relation(fields: [contributorId], references: [id])
  releaseDescription       String?       @db.VarChar(1000)
  consumers                Consumer[]    @relation("ContributionConsumers")
  collaborators            Artist[]      @relation("ContributionCollaborators")
  comments                 Comment[]
  downloadUrl              String
  sizeInBytes              Int?
  approvedAccountingBytes  BigInt?
  linkStatus               LinkHealthStatus @default(UNKNOWN)
  linkCheckedAt            DateTime?
  type                     FileType
  bitrate                  String?
  media                    String?
  hasLog                   Boolean       @default(false)
  hasCue                   Boolean       @default(false)
  isScene                  Boolean       @default(false)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  Request                  Request[]
  fills                    RequestFill[]
