{
  "name": "@stellar/api",
  "private": true,
  "version": "0.8.1",
  "description": "Stellar API",
  "author": "ayan4m1 <andrew@bulletlogic.com>, Kyle O'Brien <obrienk@webbhost.net>",
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts --esm",
    "watch": "tsc -w",
    "lint": "eslint src prisma --ext .ts",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "format": "prettier --write src 'prisma/**/*.ts'",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:integration": "DOTENV_CONFIG_PATH=.env.test node -r dotenv/config ./node_modules/jest/bin/jest.js --runInBand --config jest.integration.cjs",
    "openapi:export": "ts-node src/scripts/export-openapi.ts",
    "version:check": "ts-node -T src/scripts/check-version-consistency.ts",
    "db:generate": "prisma generate",
    "db:erd": "prisma generate --generator erd",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed-e2e": "ts-node src/scripts/seed-e2e-users.ts",
    "db:studio": "prisma studio",
    "prepare": "husky install || true"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.55.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "isomorphic-dompurify": "^3.9.0",
    "jsdom": "^29.0.2",
    "jsonwebtoken": "^9.0.2",
    "katex": "^0.16.47",
    "nodemailer": "^8.0.7",
    "prisma": "^6.19.3",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.10.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.22.9",
    "@types/bcryptjs": "^2.4.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/node": "^20.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-import-resolver-node": "^0.3.7",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^8.0.3",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.1",
    "lint-staged": "^13.2.3",
    "nodemon": "^3.0.1",
    "pg": "^8.20.0",
    "prettier": "^3.0.0",
    "prisma-erd-generator": "^2.4.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
